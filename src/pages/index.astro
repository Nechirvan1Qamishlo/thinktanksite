<html>
  <head>
    <meta charset="UTF-8" />
    <title>Azadi Library</title>
  </head>
  <body>
    <main style="font-family: Arial; max-width: 900px; margin: 40px auto; padding: 20px;">
      <h1>Azadi Library</h1>
      <p>A simple digital library for books and resources.</p>

      <input 
        type="text" 
        placeholder="Search books..." 
        style="padding: 12px; width: 100%; margin: 20px 0; font-size: 16px;"
      />

      <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
          <h2>Book Title 1</h2>
          <p>Author name</p>
          <a href="#">Read / Download</a>
        </div>

        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
          <h2>Book Title 2</h2>
          <p>Author name</p>
          <a href="#">Read / Download</a>
        </div>
      </section>
    </main>
  </body>
</html>
